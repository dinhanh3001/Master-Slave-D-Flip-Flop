{netlist dff_nonoverlap.sch_out
{version 1 1 0 }
/* nettran: AMD.64 Release B-2008.09.SP5.26004 2012/07/19 */ 
/* Created:  5/10/2026  17:56   */
/* Options: -cdl /home/itsupport/Desktop/DOAN/synopsys_custom/dff_nonoverlap.hercules.lvs/dff_nonoverlap.custom_compiler.sp -sp /home/itsupport/Desktop/DOAN/PDK/hercules/lvs/empty.subckt -cdl-a -cdl-p -mprop -slash -logFile /home/itsupport/Desktop/DOAN/D_FF_NON_VERIFY/run_details/nettran.log -outName dff_nonoverlap.sch_out  */

{net_global vdd! gnd! }
{cell not
{port in out}
{inst MM1=P
{prop M=1 NF=1 L=0.2 W=1.44}
{pin out=DRN in=GATE vdd!=SRC vdd!=BULK}}
{inst MM0=N
{prop M=1 NF=1 L=0.2 W=0.36}
{pin out=DRN in=GATE gnd!=SRC gnd!=BULK}}
}

{cell tranmision
{port in n out p}
{inst MM1=P
{prop M=1 NF=1 L=0.2 W=1.44}
{pin out=DRN p=GATE in=SRC in=BULK}}
{inst MM0=N
{prop M=1 NF=1 L=0.2 W=0.36}
{pin out=DRN n=GATE in=SRC in=BULK}}
}

{cell MOSVAR_1V2
{port PLUS MINUS BULK}
}

{cell NDN25
{port DRN GATE SRC PW PSUB DNW}
{inst q2=DNWPNP
{pin PW=COLL PSUB=BASE DNW=EMIT}}
{inst m1=N25
{pin D=DRN G=GATE S=SRC PW=BULK}}
}

{cell NDN
{port DRN GATE SRC PW PSUB DNW}
{inst q2=DNWPNP
{pin PW=COLL PSUB=BASE DNW=EMIT}}
{inst m1=N
{pin D=DRN G=GATE S=SRC PW=BULK}}
}

{cell INDSYMCT
{port PLUS MINUS CTAP BULK}
}

{cell INDSYM
{port PLUS MINUS BULK}
}

