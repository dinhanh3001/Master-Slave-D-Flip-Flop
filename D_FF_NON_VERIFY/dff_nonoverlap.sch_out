{cell dff_nonoverlap
{port D Q Q_N clk1 clk2}
{inst XI4=not
{pin net4=in net2=out}}
{inst XI5=not
{pin net2=in net3=out}}
{inst XI6=not
{pin net1=in Q=out}}
{inst XI7=not
{pin Q=in Q_N=out}}
{inst XI8=not
{pin clk1=in clk1_bar=out}}
{inst XI9=not
{pin clk2=in clk2_bar=out}}
{inst XI0=tranmision
{pin D=in clk2=n net4=out clk2_bar=p}}
{inst XI1=tranmision
{pin net2=in clk1=n net1=out clk1_bar=p}}
{inst XI2=tranmision
{pin net4=in clk2_bar=n net3=out clk2=p}}
{inst XI3=tranmision
{pin net1=in clk1_bar=n Q_N=out clk1=p}}
}

