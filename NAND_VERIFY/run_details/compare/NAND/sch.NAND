{NETLIST NAND
{VERSION 1 0 0}

{CELL NAND
    {PORT A gnd! vdd! B Y }
    {INST MM10=N {PROP n="N" Length=0.2 Width=0.72 Mult=1 }
	{PIN A=GATE net2=SRC Y=DRN }}
    {INST MM8=P {PROP n="P" Length=0.2 Width=1.8 Mult=1 }
	{PIN A=GATE vdd!=SRC Y=DRN }}
    {INST MM9=P {PROP n="P" Length=0.2 Width=1.8 Mult=1 }
	{PIN B=GATE vdd!=SRC Y=DRN }}
    {INST MM11=N {PROP n="N" Length=0.2 Width=0.72 Mult=1 }
	{PIN B=GATE gnd!=SRC net2=DRN }}
}
}
