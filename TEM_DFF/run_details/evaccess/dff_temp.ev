HEADER {
	INLIB  = D_FF
	INLIB_PATH = .    /* For Synopsys internal use only! */
	OUTLIB = dff_temp_result.gds
	OUTLIB_PATH = .    /* For Synopsys internal use only! */
	BLOCK = dff_temp
	FORMAT = OPENACCESS
	OUTPUT_FORMAT = GDSII
	LAYOUT_PATH = /home/itsupport/Desktop/DOAN/TEM_DFF
	COMPARE_DIR = /home/itsupport/Desktop/DOAN/TEM_DFF/run_details/compare
	RUN_DETAILS_DIR = /home/itsupport/Desktop/DOAN/TEM_DFF/run_details
	SCHEMATIC = /home/itsupport/Desktop/DOAN/synopsys_custom/dff_temp.hercules.lvs/dff_temp.custom_compiler.sp
	SCHEMATIC_FORMAT = CDL
	SCHEMATIC_TOP_BLOCK = dff_temp
}
TECHNOLOGY_OPTIONS {
	EXPLODE_AREFS = FALSE
	EXPLODE_CELL_SIZE_PERCENT=70
	EXPLODE_CELL_SIZE_PERCENT_OF_TOP=70
	EXPLODE_BIG_SPARSE_CELL=TRUE
	POST_VCELL_EXPLODE_CELL_SIZE <= 10
	BAR_AUTO_EXPLODE=TRUE
	POST_VCELL_EXPLODE_LOW_MEMORY=TRUE
	VIA_AUTO_EXPLODE=TRUE
	SUBLEAF_AUTO_EXPLODE=6
	CELL_SIZE_AUTO_EXPLODE <= 10
	EXPLODE_DATA_CELL_LIMIT = 4
	POST_VCELL_EXPLODE_DATA_CELL_LIMIT = 12
	EXPLODE_HOLDING_CELL_LIMIT = 1
	EXPLODE_PLACEMENT_LIMIT = 1
	VCELL_PASS   {
		STYLE = PAIRS
		ITERATE_MAX = 15
		ARRAY_ID = TRUE
		EXPLODE_INTO_VCELL = FALSE
		MIN_COUNT = 20
		TOP_PERCENT_OF_VALUE = 40 
	}
}
EVACCESS_OPTIONS {
	PATH = /home/itsupport/Desktop/DOAN/TEM_DFF/run_details/evaccess
	LIBRARY = dff_temp
	CREATE_MSG_VIEW = TRUE
	CREATE_NETLIST_VIEW = TRUE
	CREATE_XREF_VIEW = TRUE
	CREATE_GRAF_VIEW = TRUE
	CREATE_RUNSET_VIEW = TRUE
}
OPTIONS {
	AUTO_SCHEMATIC_GLOBAL_ON=TRUE
	CREATE_VUE_OUTPUT = TRUE
	GDSIN_OPTIONS= "-nl -b"
	IGNORE_CASE=FALSE
	LAYOUT_GROUND = { GND VSS }
	LAYOUT_POWER = { VDD VCC }
	NET_PREFIX = N_
	NETTRAN_OPTIONS= "-sp /home/itsupport/Desktop/DOAN/PDK/hercules/lvs/empty.subckt -cdl-a -cdl-p -mprop -slash"
	RESOLUTION=0.001
	SCHEMATIC_GROUND = { GND VSS }
	SCHEMATIC_POWER = { VDD VCC }
	IUO_DEVICE_NAME_LIST = { N, N25, NM25, NL, NH, NM, N18, N33, NDN, NDN25, NA, NA25, NA18, NA33, P, PL, PM, PH, P25, P18, P33, rm1, rm2, rm3, rm4, rm5, rm6, rm7, rm8, rm9, rnpoly, rnpolyS, rppoly, rppolyS, hrnpoly, hrppoly, rndiff, rndiffS, rpdiff, rpdiffS, rnwell, rnwdiff, rpoly, rpolyh, rpolyrf, rpolyhrf, cmim_2t, PN, PN18V, PN25V, PN33V, PN_HVT, PN_LVT, NP, NP18V, NP25V, NP33V, NP_HVT, NP_LVT, NP_NA, NP_NA18V, NP_NA25V, NP_NA33V, NWDIO, NWDIO18V, NWDIO25V, NWDIO33V, DNWDIODE, VPNP, VPNP25V, VNPN, VNPN25V, LPNP, LPNP25V, LNPN, LNPN25V, DNWPNP, SYNSTD, INDSYM, INDSYMCT, cmom_123, cmom_1234, cmom_234, xjvar, vardio }
