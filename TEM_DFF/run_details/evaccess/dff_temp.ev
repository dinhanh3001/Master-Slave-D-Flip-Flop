EQUATE CAP MOSVAR_1V2=MOSVAR_1V2 PLUS MINUS BULK { 
	FILTER=TRUE 
	MERGE_PARALLEL=TRUE 
	MERGE_SERIES=TRUE 
	USE_TOTAL_WIDTH=TRUE 
	REL_TOLERANCE[l]= { +5, -5 }
	REL_TOLERANCE[w]= { +5, -5 }
	CHECK_USER_PROPERTIES = { l, w } }
EQUATE IND SYNSTD=SYNSTD PLUS MINUS BULK { 
	FILTER=TRUE 
	MERGE_PARALLEL=TRUE 
	MERGE_SERIES=TRUE 
	USE_TOTAL_WIDTH=TRUE 
	REL_TOLERANCE[S]= { +5, -5 }
	REL_TOLERANCE[w]= { +5, -5 }
	CHECK_USER_PROPERTIES = { N, w, S, R } }
EQUATE IND INDSYM=INDSYM PLUS MINUS BULK { 
	FILTER=TRUE 
	MERGE_PARALLEL=TRUE 
	MERGE_SERIES=TRUE 
	USE_TOTAL_WIDTH=TRUE 
	REL_TOLERANCE[S]= { +5, -5 }
	REL_TOLERANCE[w]= { +5, -5 }
	CHECK_USER_PROPERTIES = { N, w, S, R } }
