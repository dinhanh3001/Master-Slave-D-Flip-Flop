	FILTER=TRUE 
	REL_TOLERANCE[S]= { +5, -5 }
	REL_TOLERANCE[w]= { +5, -5 }
	CHECK_USER_PROPERTIES = { N, w, S, R } }
EQUATE DEV DNWDIODE=DNWDIODE PW DNW PSUB { 
	FILTER=TRUE 
	CHECK_USER_PROPERTIES = { area, pj } }
EQUATE PNP VPNP=VPNP COLL BASE EMIT { 
