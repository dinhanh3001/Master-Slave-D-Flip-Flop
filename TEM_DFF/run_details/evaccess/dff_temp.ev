COPY M9S { } TEMP=top_met
COPY V8S { } TEMP=top_via_poss
BOOLEAN CAP_MIMS AND top_via_poss { } TEMP=cap_top_via
BOOLEAN V8S NOT cap_top_via { } TEMP=top_via
