	USE_TOTAL_WIDTH=TRUE 
	FILTER_OPTIONS = { NPN-1 } }
EQUATE DEV cmom=cmom_123 PLUS MINUS BULK { 
	FILTER=TRUE 
	SCHEMATIC_SWAPPABLE_PORTS= { PLUS, MINUS }
	REL_TOLERANCE[w]= { +0, -0 }
	REL_TOLERANCE[s]= { +0, -0 }
	REL_TOLERANCE[nv]= { +0, -0 }
	REL_TOLERANCE[nh]= { +0, -0 }
	REL_TOLERANCE[stm]= { +0, -0 }
	REL_TOLERANCE[spm]= { +0, -0 }
	CHECK_USER_PROPERTIES = { w, s, nv, nh, stm, spm } }
EQUATE DEV cmom=cmom_1234 PLUS MINUS BULK { 
	FILTER=TRUE 
	SCHEMATIC_SWAPPABLE_PORTS= { PLUS, MINUS }
	REL_TOLERANCE[w]= { +0, -0 }
	REL_TOLERANCE[s]= { +0, -0 }
	REL_TOLERANCE[nv]= { +0, -0 }
	REL_TOLERANCE[nh]= { +0, -0 }
